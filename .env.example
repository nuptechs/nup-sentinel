# ─────────────────────────────────────────────
# Sentinel — Environment Variables
# ─────────────────────────────────────────────

# Server
PORT=3900

# ── Storage ──────────────────────────────────
# PostgreSQL connection (if not set, uses in-memory)
# DATABASE_URL=postgresql://user:pass@localhost:5432/sentinel

# Force in-memory storage (for development/testing)
SENTINEL_MEMORY_STORAGE=true

# DB pool size
# SENTINEL_DB_POOL_MAX=10

# ── Manifest (Static Code Analyzer) ─────────
# MANIFEST_URL=http://localhost:3800
# MANIFEST_API_KEY=your-manifest-api-key

# ── AI (Diagnosis & Correction) ─────────────
# ANTHROPIC_API_KEY=sk-ant-...
# SENTINEL_AI_MODEL=claude-sonnet-4-20250514

# ── Notifications (Webhook) ─────────────────
# WEBHOOK_URL=https://your-app.com/webhooks/sentinel
# WEBHOOK_SECRET=your-hmac-secret

# ── Tracing (DebugProbe) ─────────────────────
# SENTINEL_TRACE=debugprobe
# SENTINEL_TRACE_MAX=10000

# ── CORS ─────────────────────────────────────
# SENTINEL_CORS_ORIGIN=http://localhost:5173
